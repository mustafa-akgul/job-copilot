JOB_COPILOT_LOG_LEVEL=INFO

# ── LLM (cloud) ──────────────────────────────────────────────────────────────
# Supported: openai (default) | anthropic
JOB_COPILOT_LLM_PROVIDER=openai
JOB_COPILOT_LLM_MODEL=gpt-4o-mini
JOB_COPILOT_LLM_TEMPERATURE=0.0
JOB_COPILOT_OPENAI_API_KEY=sk-...
# JOB_COPILOT_ANTHROPIC_API_KEY=sk-ant-...
# JOB_COPILOT_LLM_MODEL=claude-haiku-4-5-20251001   # if using anthropic

# ── Auth ──────────────────────────────────────────────────────────────────────
# Production: set to your Supabase project's JWT secret
#   Supabase Dashboard → Project Settings → API → JWT Secret
JOB_COPILOT_SUPABASE_JWT_SECRET=

# Local dev / pytest only — ignored when SUPABASE_JWT_SECRET is set
JOB_COPILOT_DEV_TOKEN=dev-token

# ── Database ──────────────────────────────────────────────────────────────────
# Production: Supabase connection pooler (Transaction mode, port 6543)
#   postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Local dev: omit this line — defaults to SQLite at apps/backend/data/jobcopilot.db
# JOB_COPILOT_DATABASE_URL=postgresql+asyncpg://...

# ── Mapping ───────────────────────────────────────────────────────────────────
JOB_COPILOT_FUZZY_THRESHOLD=82
